<Window x:Class="WpfApp3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <Label Content="Pizza fajtája" Background="AliceBlue" Padding="10"
                   FontSize="14" />
            <ComboBox x:Name="cb_pizzaType" FontSize="16" Padding="10" />
            <Label Content="Pizza alap" Background="AliceBlue" Padding="10"
                   FontSize="14" />
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="rb_tomato" Content="Paradicsom"
                             Margin="10" FontSize="14" />
                <RadioButton x:Name="rb_sour_cream" Content="Tejföl"
                             Margin="10" FontSize="14" />
            </WrapPanel>
            <Label Content="Extrák" Background="AliceBlue" Padding="10"
                   FontSize="16" />
            <WrapPanel x:Name="wp_extras" HorizontalAlignment="Center">
                <CheckBox x:Name="cbox_egg" Content="Tojás" FontSize="14"
                          Margin="10" />
                <CheckBox x:Name="cbox_bacon" Content="Bacon" FontSize="14"
          Margin="10" />
                <CheckBox x:Name="cbox_chocolate" Content="Csoki" FontSize="14"
          Margin="10" />
                <CheckBox x:Name="cbox_pepper" Content="Paprika" FontSize="14"
         Margin="10" />
            </WrapPanel>
            <Label Content="Megrendelő neve" Background="AliceBlue"
                   FontSize="16" Padding="10" />
            <TextBox x:Name="tbox_customer_name" FontSize="16" Padding="10" />
            <Button Content="Rendelés leadása" FontSize="16" Padding="10"
                    Click="OrderClick" />
        </StackPanel>

        <ListBox x:Name="lbox_orders" Grid.Column="1" />


    </Grid>
</Window>
