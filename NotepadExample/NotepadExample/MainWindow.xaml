<Window x:Class="NotepadExample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NotepadExample"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="9*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Slider x:Name="sl_fontSize"
                Grid.Row="0" Grid.Column="0"
                VerticalAlignment="Center"
                Minimum="8" Maximum="128" Value="24"
                TickFrequency="20"
                SmallChange="8"
                TickPlacement="Both"
                AutoToolTipPlacement="TopLeft"
                IsSnapToTickEnabled="True" />
        <ComboBox x:Name="cbox_fontFamily"
                  Grid.Row="0" Grid.Column="1"
                  VerticalAlignment="Center"
                  SelectedIndex="0">
            <TextBlock>Arial</TextBlock>
            <TextBlock>TimesNewRoman</TextBlock>
            <TextBlock>Consolas</TextBlock>
            <TextBlock>Comic Sans MS</TextBlock>
        </ComboBox>
        <ComboBox x:Name="cbox_fontColor"
                  Grid.Row="0" Grid.Column="2"
                  VerticalAlignment="Center"
                  SelectedIndex="0">
            <TextBlock>Black</TextBlock>
            <TextBlock>DarkBlue</TextBlock>
            <TextBlock>Red</TextBlock>
            <TextBlock>DarkGreen</TextBlock>
        </ComboBox>

        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                 Text="Ez egy notepad"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 FontSize="{Binding ElementName=sl_fontSize, Path=Value}"
                 FontFamily="{Binding ElementName=cbox_fontFamily, Path=SelectedItem.Text}"
                 Foreground="{Binding ElementName=cbox_fontColor, Path=SelectedItem.Text}"/>

    </Grid>
</Window>
